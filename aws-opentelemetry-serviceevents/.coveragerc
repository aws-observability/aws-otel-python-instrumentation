[run]
parallel = true

[paths]
source =
    aws-opentelemetry-serviceevents/src/amazon
    .tox/3.*/lib/python*/site-packages/amazon
    */site-packages/amazon

[report]
include_namespace_packages = true
fail_under = 70.00
precision = 2
omit =
    */tests/*
    */pip-build-env-*/*
exclude_lines =
    pragma: no cover
    @unittest.skip
    @unittest.skipIf
    @pytest.mark.skip
    @pytest.mark.skipif
